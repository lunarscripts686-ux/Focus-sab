function updateKeybindButtons()
    for name, btn in pairs(keybindButtons) do
        local key = name:gsub(" ", ""):lower()
        btn.Text = keybinds[key] or "None"
        btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    end
end

