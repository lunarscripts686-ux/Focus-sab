local function createSpeedInput(name, value, callback, min, max)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0.95, 0, 0, 35)
    frame.Position = UDim2.new(0.025, 0, 0, 0)
    frame.BackgroundTransparency = 1
    frame.Parent = speedContainer
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, -3, 1, 0)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 13
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0.45, -3, 1, 0)
    box.Position = UDim2.new(0.55, 0, 0, 0)
    box.BackgroundColor3 = Color3.fromRGB(40,40,40)
    box.TextColor3 = Color3.fromRGB(255,255,255)
    box.Text = tostring(value)
    box.Font = Enum.Font.Gotham
    box.TextSize = 13
    box.BorderSizePixel = 0
    box.Parent = frame
    Instance.new("UICorner", box).CornerRadius = UDim.new(0,6)
    
    box.FocusLost:Connect(function()
        local num = tonumber(box.Text)
        if num and num >= min and num <= max then
            callback(num)
        else
            box.Text = tostring(value)
        end
    end)
    
    return box
end

