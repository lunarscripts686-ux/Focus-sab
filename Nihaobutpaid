-- ===== KEYBIND HANDLER =====
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if waitingForKeybind then
        local key = input.KeyCode
        if key ~= Enum.KeyCode.Unknown then
            keybinds[waitingForKeybind] = key.Name
            waitingForKeybind = nil
            updateKeybindButtons()
        end
        return
    end
    
    -- Check keybinds
    for feature, key in pairs(keybinds) do
        if input.KeyCode.Name == key then
            if feature == "autoLeft" then
                if patrolMode == "left" then
                    stopMovement()
                    autoLeftEnabled = false
                else
                    stopMovement()
                    waitingForCountdownLeft = true
                    autoLeftEnabled = true
                end
            elseif feature == "autoRight" then
                if patrolMode == "right" then
                    stopMovement()
                    autoRightEnabled = false
                else
                    stopMovement()
                    waitingForCountdownRight = true
                    autoRightEnabled = true
                end
            elseif feature == "speedBoost" then
                speedBoostEnabled = not speedBoostEnabled
                if speedBoostEnabled then stealBoostEnabled = false end
                updateSpeed()
            elseif feature == "stealBoost" then
                stealBoostEnabled = not stealBoostEnabled
                if stealBoostEnabled then speedBoostEnabled = false end
                updateSpeed()
            elseif feature == "autoMedusa" then
                autoMedusaEnabled = not autoMedusaEnabled
                if not autoMedusaEnabled then medusaTriggeredEnemies = {} end
            elseif feature == "autoBat" then
                autoBatEnabled = not autoBatEnabled
            elseif feature == "autoGrab" then
                grabEnabled = not grabEnabled
                if grabEnabled then startGrab() else stopGrab() end
            elseif feature == "antiRagdoll" then
                antiRagdollEnabled = not antiRagdollEnabled
            elseif feature == "antiRespawn" then
                antiRespawnEnabled = not antiRespawnEnabled
            elseif feature == "toggleGUI" then
                mainFrame.Visible = not mainFrame.Visible
            end
        end
    end
end)

