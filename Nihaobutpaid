local configFolder = "UltimateFocusSabConfig"

local function saveConfig()
    local data = {
        autoLeftSpeed = autoLeftSpeed,
        autoRightSpeed = autoRightSpeed,
        autoLeftReturnSpeed = autoLeftReturnSpeed,
        autoRightReturnSpeed = autoRightReturnSpeed,
        speedBoostValue = speedBoostValue,
        stealBoostValue = stealBoostValue,
        batReach = batReach,
        grabRange = grabRange,
        keybinds = keybinds
    }
    
    if not isfolder(configFolder) then
        makefolder(configFolder)
    end
    
    local file = configFolder .. "/config.txt"
    writefile(file, game:GetService("HttpService"):JSONEncode(data))
    
    if saveBtn then
        saveBtn.Text = "SAVED!"
        saveBtn.BackgroundColor3 = Color3.fromRGB(40, 80, 40)
        task.wait(1)
        saveBtn.Text = "SAVE"
        saveBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    end
end

local function loadConfig()
    local file = configFolder .. "/config.txt"
    if isfile(file) then
        local success, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(readfile(file))
        end)
        
        if success then
            autoLeftSpeed = data.autoLeftSpeed or 60
            autoRightSpeed = data.autoRightSpeed or 60
            autoLeftReturnSpeed = data.autoLeftReturnSpeed or 30
            autoRightReturnSpeed = data.autoRightReturnSpeed or 30
            speedBoostValue = data.speedBoostValue or 55
            stealBoostValue = data.stealBoostValue or 30
            batReach = data.batReach or 18
            grabRange = data.grabRange or 25
            if data.keybinds then
                for k, v in pairs(data.keybinds) do
                    keybinds[k] = v
                end
            end
        end
    end
end

loadConfig()

-- ===== UTILITY FUNCTIONS =====
local function getHRP()
    local char = lp.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = lp.Character
    return char and char:FindFirstChild("Humanoid")
end

local function updateSpeed()
    local hum = getHumanoid()
    if not hum then return end
    
    if speedBoostEnabled then
        hum.WalkSpeed = speedBoostValue
    elseif stealBoostEnabled then
        hum.WalkSpeed = stealBoostValue
    else
        hum.WalkSpeed = DEFAULT_WALKSPEED
    end
end

-- ===== AUTO LEFT/RIGHT MOVEMENT =====
local function getCurrentSpeed()
    if patrolMode == "right" then
        if currentWaypoint >= 3 then
            return autoRightReturnSpeed
        else
            return autoRightSpeed
        end
    elseif patrolMode == "left" then
        if currentWaypoint >= 3 then
            return autoLeftReturnSpeed
        else
            return autoLeftSpeed
        end
    end
    return 0
end

local function getCurrentWaypoints()
    if patrolMode == "right" then
        return rightWaypoints
    elseif patrolMode == "left" then
        return leftWaypoints
    end
    return {}
end

local function startMovement(mode)
    patrolMode = mode
    currentWaypoint = 1
    waitingAtWaypoint2 = false
end

local function stopMovement()
    patrolMode = "none"
    currentWaypoint = 1
    waitingAtWaypoint2 = false
    waitingForCountdownLeft = false
    waitingForCountdownRight = false
    
    local char = lp.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then
            root.AssemblyLinearVelocity = Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
        end
    end
end

local function isCountdownNumber(text)
    local num = tonumber(text)
    if num and num >= 1 and num <= 5 then
        return true, num
    end
    return false
end

local function isTimerInCountdown(label)
    if not label then return false end
    local ok, num = isCountdownNumber(label.Text)
    return ok and num >= 1 and num <= 5
end

-- ===== AUTO MEDUSA (SUPERIOR) =====
local function unequipBat()
    local char = lp.Character
    if not char then return end
    
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name:lower():find("bat") or tool.Name == "Bat") then
            local backpack = lp:FindFirstChild("Backpack")
            if backpack then
                tool.Parent = backpack
            end
            break
        end
    end
end

local function unequipMedusa()
    local char = lp.Character
    if not char then return end
    
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and tool.Name:lower():find("medusa") then
            local backpack = lp:FindFirstChild("Backpack")
            if backpack then
                tool.Parent = backpack
            end
            medusaActive = false
            break
        end
    end
end

local function findMedusaTool()
    local char = lp.Character
    if not char then return nil end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and tool.Name:lower():find("medusa") then
            return tool
        end
    end
    local backpack = lp:FindFirstChild("Backpack")
    if backpack then
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool.Name:lower():find("medusa") then
                return tool
            end
        end
    end
    return nil
end

local function getNearestEnemy()
    local hrp = getHRP()
    if not hrp then return nil end
    local nearest, minDist = nil, medusaDistance
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= lp then
            local char = plr.Character
            if char then
                local targetHRP = char:FindFirstChild("HumanoidRootPart")
                if targetHRP then
                    local dist = (hrp.Position - targetHRP.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = plr
                    end
                end
            end
        end
    end
    return nearest, minDist
end

local function activateMedusa()
    if not autoMedusaEnabled then return end
    if medusaActive then return end
    
    local now = tick()
    if now - lastMedusaUse < medusaCooldown then return end
    
    local medusaTool = findMedusaTool()
    if medusaTool then
        unequipBat()
        
        if medusaTool.Parent == lp.Backpack then
            local hum = getHumanoid()
            if hum then 
                hum:EquipTool(medusaTool)
                medusaActive = true
            end
        end
        
        task.wait(0.1)
        medusaTool:Activate()
        lastMedusaUse = now
        
        task.wait(0.5)
        unequipMedusa()
    end
end

-- ===== AUTO BAT =====
local function findBat()
    if medusaActive then return nil end
    
    local char = lp.Character
    if not char then return nil end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name:lower():find("bat") or tool.Name == "Bat") then
            return tool
        end
    end
    local backpack = lp:FindFirstChild("Backpack")
    if backpack then
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and (tool.Name:lower():find("bat") or tool.Name == "Bat") then
                return tool
            end
        end
    end
    return nil
end

local function equipBat(bat)
    if not bat then return false end
    if medusaActive then return false end
    if bat.Parent == lp.Character then return true end
    if bat.Parent == lp.Backpack then
        local hum = getHumanoid()
        if hum then
            hum:EquipTool(bat)
            return true
        end
    end
    return false
end

local function getNearestPlayerForBat()
    local hrp = getHRP()
    if not hrp then return nil end
    local nearest, minDist = nil, batReach
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= lp then
            local char = plr.Character
            if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                local targetHRP = char:FindFirstChild("HumanoidRootPart")
                if targetHRP then
                    local dist = (hrp.Position - targetHRP.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = plr
                    end
                end
            end
        end
    end
    return nearest, minDist
end

-- ===== AUTO GRAB =====
local function getPromptPart(prompt)
    local p = prompt.Parent
    if p:IsA("BasePart") then return p end
    if p:IsA("Model") then return p.PrimaryPart or p:FindFirstChildWhichIsA("BasePart") end
    if p:IsA("Attachment") then return p.Parent end
    return p:FindFirstChildWhichIsA("BasePart", true)
end

local function findStealPrompt()
    local hrp = getHRP()
    if not hrp then return end
    local nearest, minDist = nil, math.huge
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return end
    for _, desc in pairs(plots:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Enabled and desc.ActionText == "Steal" then
            local part = getPromptPart(desc)
            if part then
                local d = (hrp.Position - part.Position).Magnitude
                if d < minDist then
                    minDist = d
                    nearest = desc
                end
            end
        end
    end
    return nearest, minDist
end

local function makePromptsVisible()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return end
    
    for _, desc in pairs(plots:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.ActionText == "Steal" then
            desc.MaxActivationDistance = 9e9
            desc.RequiresLineOfSight = false
            desc.ClickablePrompt = true
        end
    end
end

local function triggerPrompt(prompt)
    if not prompt or not prompt:IsDescendantOf(workspace) then return end
    
    prompt.MaxActivationDistance = 9e9
    prompt.RequiresLineOfSight = false
    prompt.ClickablePrompt = true
    
    local ok = pcall(fireproximityprompt, prompt, 9e9, 0)
    if not ok then
        pcall(function()
            prompt:InputHoldBegin()
            task.wait(0)
            prompt:InputHoldEnd()
        end)
    end
end

local function createGrabCircle()
    if grabCircleObj then
        grabCircleObj:Destroy()
        grabCircleObj = nil
    end
    
    if not showGrabCircle or not grabEnabled then return end
    
    local char = lp.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local circle = Instance.new("Part")
    circle.Size = Vector3.new(grabRange * 2, 0.2, grabRange * 2)
    circle.Position = hrp.Position
    circle.Anchored = true
    circle.CanCollide = false
    circle.Transparency = 0.7
    circle.BrickColor = BrickColor.new("Really blue")
    circle.Material = Enum.Material.Neon
    circle.Parent = workspace
    circle.Name = "GrabRangeCircle"
    
    local attachment = Instance.new("Attachment")
    attachment.Parent = circle
    
    grabCircleObj = circle
    
    -- Update circle position to follow player
    RunService.Heartbeat:Connect(function()
        if grabCircleObj and grabEnabled and showGrabCircle then
            local newHrp = getHRP()
            if newHrp then
                grabCircleObj.Position = newHrp.Position
            end
        elseif grabCircleObj then
            grabCircleObj:Destroy()
            grabCircleObj = nil
        end
    end)
end

local function startGrab()
    if grabLoop then grabLoop:Disconnect() end
    
    makePromptsVisible()
    createGrabCircle()
    
    grabLoop = RunService.Heartbeat:Connect(function()
        if not grabEnabled then return end
        
        local prompt, dist = findStealPrompt()
        if prompt and dist <= grabRange then
            triggerPrompt(prompt)
        end
        task.wait(0)
    end)
end

local function stopGrab()
    if grabLoop then grabLoop:Disconnect(); grabLoop = nil end
    if grabCircleObj then
        grabCircleObj:Destroy()
        grabCircleObj = nil
    end
end

-- ===== ANTI-RAGDOLL =====
local function isRagdolled(char)
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return false end
    local state = hum:GetState()
    if state == Enum.HumanoidStateType.Physics
    or state == Enum.HumanoidStateType.FallingDown
    or state == Enum.HumanoidStateType.Ragdoll then
        return true
    end
    return false
end

local function recoverFromRagdoll()
    local char = lp.Character
    if not char then return end
    
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end
    
    hum:ChangeState(Enum.HumanoidStateType.Running)
    hum.PlatformStand = false
    hum.Sit = false
    hum.AutoRotate = true
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.Velocity = Vector3.zero
        hrp.RotVelocity = Vector3.zero
    end
    
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("JointInstance") and v.Enabled == false then
            v.Enabled = true
        end
        if v:IsA("Constraint") and (v.Name:lower():find("rag") or v.Name:lower():find("doll")) then
            v:Destroy()
        end
    end
end

-- ===== ANTI-RESPAWN =====
local function preventRespawn()
    if not antiRespawnEnabled then return end
    
    local char = lp.Character
    if not char then
        local newChar = Instance.new("Model")
        newChar.Name = "Character"
        newChar.Parent = workspace
        
        local hrp = Instance.new("Part")
        hrp.Name = "HumanoidRootPart"
        hrp.Anchored = true
        hrp.Parent = newChar
        
        local hum = Instance.new("Humanoid")
        hum.Parent = newChar
        
        lp.Character = newChar
        characterLocked = true
    end
end

-- ===== MOVEMENT LOOP =====
local function updateWalking()
    local char = lp.Character
    if not char then return end

    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not root or not hum then return end

    if patrolMode ~= "none" then
        local waypoints = getCurrentWaypoints()
        local targetPos = waypoints[currentWaypoint]
        local currentPos = root.Position

        local targetXZ = Vector3.new(targetPos.X, 0, targetPos.Z)
        local currentXZ = Vector3.new(currentPos.X, 0, currentPos.Z)
        local distanceXZ = (targetXZ - currentXZ).Magnitude

        if distanceXZ > 3 then
            local moveDirection = (targetXZ - currentXZ).Unit
            local currentSpeed = getCurrentSpeed()

            root.AssemblyLinearVelocity = Vector3.new(
                moveDirection.X * currentSpeed,
                root.AssemblyLinearVelocity.Y,
                moveDirection.Z * currentSpeed
            )
        else
            if currentWaypoint == 2 and not waitingAtWaypoint2 then
                waitingAtWaypoint2 = true
                root.AssemblyLinearVelocity = Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
                task.spawn(function()
                    task.wait(PAUSE_AT_WAYPOINT_2)
                    if patrolMode ~= "none" and currentWaypoint == 2 then
                        currentWaypoint = 3
                        waitingAtWaypoint2 = false
                    end
                end)
            elseif currentWaypoint == 2 and waitingAtWaypoint2 then
                root.AssemblyLinearVelocity = Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
            elseif currentWaypoint == #waypoints then
                stopMovement()
            else
                currentWaypoint = currentWaypoint + 1
            end
        end
    end
end

-- ===== HEARTBEAT CONNECTION =====
RunService.Heartbeat:Connect(function()
    local char = lp.Character
    if not char then return end
    
    -- Auto Left/Right movement
    updateWalking()
    
    -- Speed/Steal boost
    updateSpeed()
    
    -- Auto Medusa
    if autoMedusaEnabled then
        local enemy = getNearestEnemy()
        if enemy and enemy.Character then
            if not medusaTriggeredEnemies[enemy] then
                medusaTriggeredEnemies[enemy] = true
                task.spawn(function()
                    task.wait(0.1)
                    activateMedusa()
                    task.wait(2)
                    medusaTriggeredEnemies[enemy] = false
                end)
            end
        end
    end
    
    -- Auto Bat
    if autoBatEnabled and not medusaActive then
        local bat = findBat()
        local target = getNearestPlayerForBat()
        if bat and target and target.Character then
            equipBat(bat)
            bat:Activate()
        end
    end
    
    -- Anti-Ragdoll
    if antiRagdollEnabled and char then
        local ragdollNow = isRagdolled(char)
        if ragdollNow and not wasRagdolled then
            recoverFromRagdoll()
        end
        wasRagdolled = ragdollNow
    end
    
    -- Anti-Respawn
    if antiRespawnEnabled then
        preventRespawn()
    end
end)

