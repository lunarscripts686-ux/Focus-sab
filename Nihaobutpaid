local keybindButtons = {}

local function createKeybindInput(name, key)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0.95, 0, 0, 35)
    frame.Position = UDim2.new(0.025, 0, 0, 0)
    frame.BackgroundTransparency = 1
    frame.Parent = keybindContainer
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, -3, 1, 0)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 13
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.45, -3, 1, 0)
    btn.Position = UDim2.new(0.55, 0, 0, 0)
    btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Text = key
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 13
    btn.BorderSizePixel = 0
    btn.Parent = frame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)
    
    btn.MouseButton1Click:Connect(function()
        waitingForKeybind = name:gsub(" ", ""):lower()
        btn.Text = "Press Key..."
        btn.BackgroundColor3 = Color3.fromRGB(80, 40, 40)
    end)
    
    keybindButtons[name] = btn
    return btn
end

createKeybindInput("Auto Left", keybinds.autoLeft)
createKeybindInput("Auto Right", keybinds.autoRight)
createKeybindInput("Speed Boost", keybinds.speedBoost)
createKeybindInput("Steal Boost", keybinds.stealBoost)
