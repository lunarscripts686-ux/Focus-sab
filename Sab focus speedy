local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local lp = player

local speedBoostEnabled = false
local stealBoostEnabled = false
local speedBoostValue = 55
local stealBoostValue = 30
local DEFAULT_WALKSPEED = 16

local configFolder = "SpeedBoostConfig"

local function saveConfig()
    local data = {
        speedBoostEnabled = speedBoostEnabled,
        stealBoostEnabled = stealBoostEnabled,
        speedBoostValue = speedBoostValue,
        stealBoostValue = stealBoostValue,
    }
    
    if not isfolder(configFolder) then
        makefolder(configFolder)
    end
    
    local file = configFolder .. "/config.txt"
    writefile(file, game:GetService("HttpService"):JSONEncode(data))
    
    saveBtn.Text = "SAVED!"
    saveBtn.BackgroundColor3 = Color3.fromRGB(40, 80, 40)
    task.wait(1)
    saveBtn.Text = "SAVE"
    saveBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
end

local function loadConfig()
    local file = configFolder .. "/config.txt"
    if isfile(file) then
        local success, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(readfile(file))
        end)
        
        if success then
            speedBoostEnabled = data.speedBoostEnabled or false
            stealBoostEnabled = data.stealBoostEnabled or false
            speedBoostValue = data.speedBoostValue or 55
            stealBoostValue = data.stealBoostValue or 30
        end
    end
end

loadConfig()

local function getHumanoid()
    local char = lp.Character
    return char and char:FindFirstChild("Humanoid")
end

local function updateSpeed()
    local hum = getHumanoid()
    if not hum then return end
    
    if speedBoostEnabled then
        hum.WalkSpeed = speedBoostValue
    elseif stealBoostEnabled then
        hum.WalkSpeed = stealBoostValue
    else
        hum.WalkSpeed = DEFAULT_WALKSPEED
    end
end

RunService.Heartbeat:Connect(updateSpeed)

lp.CharacterAdded:Connect(function()
    task.wait(0.5)
    updateSpeed()
end)

