local function addHover(btn, getter)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(70,70,70)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        if getter and getter() then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40,80,40)}):Play()
        else
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(45,45,45)}):Play()
        end
    end)
end

addHover(speedBtn, function() return speedBoostEnabled end)
addHover(stealBtn, function() return stealBoostEnabled end)
addHover(saveBtn, function() return false end)

speedBtn.MouseButton1Click:Connect(function()
    if speedBoostEnabled then
        speedBoostEnabled = false
    else
        stealBoostEnabled = false
        speedBoostEnabled = true
        stealBtn.Text = "STEAL OFF"
        stealBtn.BackgroundColor3 = Color3.fromRGB(45,45,45)
    end
    speedBtn.Text = speedBoostEnabled and "SPEED ON" or "SPEED OFF"
    speedBtn.BackgroundColor3 = speedBoostEnabled and Color3.fromRGB(40,80,40) or Color3.fromRGB(45,45,45)
    updateSpeed()
end)

stealBtn.MouseButton1Click:Connect(function()
    if stealBoostEnabled then
        stealBoostEnabled = false
    else
        speedBoostEnabled = false
        stealBoostEnabled = true
        speedBtn.Text = "SPEED OFF"
        speedBtn.BackgroundColor3 = Color3.fromRGB(45,45,45)
    end
    stealBtn.Text = stealBoostEnabled and "STEAL ON" or "STEAL OFF"
    stealBtn.BackgroundColor3 = stealBoostEnabled and Color3.fromRGB(40,80,40) or Color3.fromRGB(45,45,45)
    updateSpeed()
end)

speedBox.FocusLost:Connect(function()
    local num = tonumber(speedBox.Text)
    if num and num >= 10 and num <= 200 then
        speedBoostValue = num
        if speedBoostEnabled then updateSpeed() end
    else
        speedBox.Text = tostring(speedBoostValue)
    end
end)

